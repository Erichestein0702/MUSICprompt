# MUSICprompt 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ===== LLM 服务配置 =====

# SiliconFlow API (用于翻译)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# Google Gemini API (用于炼金处理)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# LLM 请求间隔（秒），免费版建议 0.5+
# LLM_REQUEST_INTERVAL=0.5

# ===== Reddit 爬虫配置 =====

# 目标子版块，逗号分隔
# REDDIT_SUBREDDITS=SunoAI,Udio,aiMusic

# 最低点赞数阈值
# MIN_UPVOTES=50

# 每日目标获取数量
# TARGET_COUNT=7

# Reddit RSS 请求超时（秒）
# REDDIT_REQUEST_TIMEOUT=30

# ===== 数据处理配置 =====

# Prompt 最小/最大长度
# MIN_PROMPT_LENGTH=20
# MAX_PROMPT_LENGTH=2000

# 最低质量分数（低于此分的 prompt 被过滤）
# MIN_QUALITY_SCORE=5.0

# 批量处理大小
# BATCH_SIZE=20

# ===== 数据库配置 =====
# DB_PATH=data/musicprompts.db
# SEARCH_LIMIT_DEFAULT=20
